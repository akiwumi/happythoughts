  "font-family-base": "Inter, Roboto, -apple-system, system-ui, 'Segoe UI', 'Helvetica Neue', Arial",
  "font-sizes": {
    "xs": "12px",
    "sm": "14px",
    "md": "16px",
    "lg": "18px",
    "xl": "20px"
  },
