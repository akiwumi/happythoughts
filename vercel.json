{
  "version": 2,
  "buildCommand": "cd frontend && npm install --include=dev && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "backend/api.ts": {
      "includeFiles": "backend/**"
    }
  },
  "routes": [
    { "src": "/_/backend/(.*)", "dest": "/backend/api.ts" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
